<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HARI BHAI.V.DESAI College Portal</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(to right, #1e3c72, #2a5298);
            color: white;
        }

        .navbar {
            background: rgba(0,0,0,0.7);
        }

        .hero {
            height: 90vh;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .hero h1 {
            font-size: 50px;
            font-weight: 600;
        }

        .hero p {
            font-size: 18px;
            margin-top: 10px;
        }

        .btn-custom {
            padding: 12px 25px;
            border-radius: 30px;
            font-size: 18px;
        }

        .features {
            background: white;
            color: black;
            padding: 50px 20px;
        }

        .feature-box {
            text-align: center;
            padding: 20px;
        }

        footer {
            background: black;
            padding: 10px;
            text-align: center;
        }
    </style>
</head>
<body>

<!-- 🔝 NAVBAR -->
<nav class="navbar navbar-dark px-4">
    <span class="navbar-brand d-flex align-items-center">
        <img src="/static/logo.png" width="40" class="me-2">
        <strong>HARI BHAI.V.DESAI</strong>
    </span>
</nav>

<!-- 🎯 HERO SECTION -->
<div class="hero">
    <div>
        <h1>College Resource Portal</h1>
        <p>Access Notes, Previous Year Questions & Study Materials Easily</p>

        <div class="mt-4">
            <a href="/login/student" class="btn btn-light btn-custom me-3">🎓 Student Login</a>
            <a href="/login/teacher" class="btn btn-warning btn-custom">👨‍🏫 Teacher Login</a>
        </div>
    </div>
</div>

<!-- ⭐ FEATURES SECTION -->
<div class="features">
    <div class="container">
        <div class="row">

            <div class="col-md-4 feature-box">
                <h4>📂 Notes Access</h4>
                <p>Download subject-wise notes anytime</p>
            </div>

            <div class="col-md-4 feature-box">
                <h4>📄 Previous Papers</h4>
                <p>Get previous year question papers</p>
            </div>

            <div class="col-md-4 feature-box">
                <h4>⬆ Easy Upload</h4>
                <p>Teachers can upload & manage content</p>
            </div>

        </div>
    </div>
</div>

<!-- 🔻 FOOTER -->
<footer>
    <p>© 2026 HARI BHAI.V.DESAI College | All Rights Reserved</p>
</footer>

</body>
</html>
